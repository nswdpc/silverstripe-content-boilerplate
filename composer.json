{
    "name": "nswdpc/silverstripe-content-boilerplate",
    "description": "A collection of modules we use to help our content authors make great websites",
    "type": "silverstripe-vendormodule",
    "license": "BSD-3-Clause",
    "authors": [
        {
            "name": "James Ellis",
            "role": "Developer"
        },
        {
            "name": "Mark Taylor",
            "role": "Developer"
        }
    ],
    "keywords": [
        "silverstripe",
        "content",
        "content authoring",
        "user experience"
    ],
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/nswdpc/silverstripe-link.git"
        },
        {
            "type": "vcs",
            "url": "https://github.com/nswdpc/silverstripe-linkfield.git"
        }
    ],
    "require": {
        "bummzack/sortablefile": "^3",
        "dnadesign/silverstripe-elemental": "^6",
        "dnadesign/silverstripe-elemental-list": "^3",
        "dnadesign/silverstripe-elemental-virtual": "^3",
        "dnadesign/silverstripe-elemental-userforms": "^5",
        "firebrandhq/silverstripe-phonelink": "^4",
        "gorriecoe/silverstripe-linkfield": "dev-ss6",
        "innoweb/silverstripe-robots": "^6",
        "innoweb/silverstripe-social-metadata": "^9",
        "jonom/focuspoint": "^6",
        "jonom/silverstripe-text-target-length": "^2.0.4",
        "nswdpc/silverstripe-dataobject-editable": "dev-ss6",
        "nswdpc/silverstripe-datetime-inputs": "dev-ss6",
        "nswdpc/silverstripe-elemental-banner": "dev-ss6",
        "nswdpc/silverstripe-elemental-decoratedcontent": "dev-ss6",
        "nswdpc/silverstripe-elemental-feature-video": "dev-ss6",
        "nswdpc/silverstripe-elemental-iframe": "dev-ss6",
        "nswdpc/silverstripe-elemental-image": "dev-ss6",
        "nswdpc/silverstripe-elemental-links": "dev-ss6",
        "nswdpc/silverstripe-elemental-modeladmin": "dev-ss6",
        "nswdpc/silverstripe-elemental-publications": "dev-ss6",
        "nswdpc/silverstripe-elemental-quickgallery": "dev-ss6",
        "nswdpc/silverstripe-schema-specialannouncement": "dev-ss6",
        "nswdpc/silverstripe-elemental-slider": "dev-ss6",
        "nswdpc/silverstripe-elemental-taxonomy": "dev-ss6",
        "nswdpc/silverstripe-inline-linker": "dev-ss6",
        "nswdpc/silverstripe-recaptcha-v3-userforms": "dev-ss6",
        "nswdpc/silverstripe-thereisnouserform": "dev-ss6",
        "nswdpc/silverstripe-embed": "dev-ss6",
        "purplespider/asset-alt-text": "^3",
        "silverstripe/admin": "^3",
        "silverstripe/asset-admin": "^3",
        "silverstripe/cms": "^6",
        "silverstripe/contentreview": "^6",
        "silverstripe/errorpage": "^3",
        "silverstripe/gridfieldqueuedexport": "^4",
        "silverstripe/htmleditor-tinymce": "^1",
        "silverstripe/lumberjack": "^4",
        "silverstripe/mimevalidator": "^4",
        "silverstripe/reports": "6",
        "silverstripe/sharedraftcontent": "^4",
        "silverstripe/siteconfig": "^6",
        "silverstripe/userforms": "^7",
        "silverstripe/versioned": "^3",
        "silverstripe/versioned-admin": "^3",
        "symbiote/silverstripe-advancedworkflow": "^7",
        "symbiote/silverstripe-gridfieldextensions": "^5",
        "symbiote/silverstripe-multivaluefield": "^7",
        "unclecheese/display-logic": "^4",
        "wilr/silverstripe-googlesitemaps": "^4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "friendsofphp/php-cs-fixer": "^3",
        "cambis/silverstripe-rector": "^2",
        "cambis/silverstan": "^2",
        "nswdpc/ci-files": "dev-v-4",
        "phpstan/phpstan": "^2",
        "phpstan/phpstan-phpunit": "^2",
        "rector/rector": "^2"
    },
    "scripts": {
        "phpstan-analyse": "./vendor/bin/phpstan analyse --ansi --no-progress --no-interaction --configuration vendor/nswdpc/ci-files/phpstan/.phpstan.silverstripe.neon ./_config.php",
        "rector-dryrun": "./vendor/bin/rector process --dry-run --ansi --config vendor/nswdpc/ci-files/rector/.rector.silverstripe_6_83.php ./_config.php",
        "rector-process": "./vendor/bin/rector process --no-diffs --ansi --config vendor/nswdpc/ci-files/rector/.rector.silverstripe_6_83.php ./_config.php",
        "phpcsfixer-fix": "./vendor/bin/php-cs-fixer fix --ansi --no-interaction --config vendor/nswdpc/ci-files/php-cs-fixer/.php-cs-fixer.php ./_config.php"
    },
    "autoload": {
        "psr-4": {
            "NSWDPC\\Content\\": "src/"
        }
    },
    "config": {
        "process-timeout": 600,
        "allow-plugins": {
            "composer/installers": true,
            "silverstripe/vendor-plugin": true
        }
    },
    "extra": {
        "expose": [
            "client/static"
        ]
    },
    "prefer-stable": true,
    "minimum-stability": "dev"
}
